    "total = 0\n",
    "evensum = 0\n",
    "oddsum = 0\n",
    "for i in range(1,11):\n",
    "    total += i\n",
    "    \n",
    "    if i % 2 == 0:\n",
    "        evensum += i\n",
    "    else:\n",
    "        oddsum += i\n",
    "        \n",
    "print(\"total sum :\",total)\n",
    "print(\"even sum :\",evensum)\n",
    "print(\"odd sum :\",oddsum)\n",
    "        "
